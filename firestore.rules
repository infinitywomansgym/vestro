rules_version = '2';

// Vestro by RA — Firestore security rules
// Products are PUBLIC to read (the shop shows them) but only the shop
// OWNER may add / edit / delete them. "Owner" = whoever is signed in with
// the owner email below. A stranger can create their own Firebase account,
// but they can NEVER get a login token carrying this email (it already
// exists and they don't have the password), so they cannot write.
//
// When RA's own login is created later, add its email to isOwner() too.

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner() {
      return request.auth != null
        && request.auth.token.email in [
             'admin@vestro.com'
             // , 'ra@example.com'   // <- add RA's real login email here later
           ];
    }

    match /products/{productId} {
      allow read: if true;        // shop is public
      allow write: if isOwner();  // only the owner can change products
    }

    // Everything else is locked by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
